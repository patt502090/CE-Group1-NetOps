  </rule>
</group>

<!-- ===== L3 Switch 10.1.50.1 ===== -->
<group name="cisco,l3switch,syslog,">

  <rule id="100200" level="3">
    <decoded_as>cisco-l3switch</decoded_as>
    <description>Cisco L3 Switch (10.1.50.1) - Generic log</description>
  </rule>

  <rule id="100201" level="8">
    <if_sid>100200</if_sid>
    <match>%LINK-3-UPDOWN</match>
    <description>Cisco L3 Switch (10.1.50.1) - Interface state change</description>
  </rule>

  <rule id="100202" level="10">
    <if_sid>100200</if_sid>
    <match>%OSPF-|%EIGRP-|%BGP-</match>
    <description>Cisco L3 Switch (10.1.50.1) - Routing protocol event</description>
  </rule>

  <rule id="100203" level="8">
    <if_sid>100200</if_sid>
    <match>%HSRP-|%VRRP-</match>
    <description>Cisco L3 Switch (10.1.50.1) - FHRP event</description>
  </rule>

  <rule id="100204" level="5">
    <if_sid>100200</if_sid>
    <match>%SYS-5-CONFIG_I</match>
    <description>Cisco L3 Switch (10.1.50.1) - Configuration changed</description>
  </rule>

  <rule id="100205" level="8">
    <if_sid>100200</if_sid>
    <match>%SEC_LOGIN-4-LOGIN_FAILED</match>
    <description>Cisco L3 Switch (10.1.50.1) - Login failed</description>
  </rule>

  <rule id="100206" level="5">
    <if_sid>100200</if_sid>
    <match>%LINEPROTO-5-UPDOWN</match>
    <description>Cisco L3 Switch (10.1.50.1) - Line protocol state change</description>
  </rule>

</group>

